      "scope": "storage.modifier",
      "settings": {
        "foreground": "#80FFBB"
      }
    },
    {
      "name": "Storage Type Function",
      "scope": "storage.type.function",
      "settings": {
        "foreground": "#FB94FF"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#A5FF90"
      }
    },
    {
      "name": "String Template",
      "scope": "string.template",
