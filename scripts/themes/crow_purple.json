      "scope": "punctuation.definition.tag",
      "settings": {
        "foreground": "#9EFFFF"
      }
    },
    {
      "name": "CSS Entity",
      "scope": "source.css entity",
      "settings": {
        "foreground": "#3AD900"
      }
    },
    {
      "name": "CSS Class Selector",
      "scope": "entity.other.attribute-name.class.css",
      "settings": {
